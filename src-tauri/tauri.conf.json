{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loavy Player",
  "version": "2.0.0",
  "identifier": "com.loavy.player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Loavy Player",
        "width": 1240,
        "height": 800,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data:; media-src 'self' asset: http://asset.localhost; connect-src 'self' https://musicbrainz.org https://coverartarchive.org; style-src 'self' 'unsafe-inline'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
